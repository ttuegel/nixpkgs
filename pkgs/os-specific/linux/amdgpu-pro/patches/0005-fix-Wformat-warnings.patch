Subject: [PATCH 5/7] fix Wformat warnings

---
 amd/amdgpu/amdgpu_sa.c | 5 -----
 1 file changed, 5 deletions(-)

diff --git a/amd/amdgpu/amdgpu_sa.c b/amd/amdgpu/amdgpu_sa.c
index 1b217c6..d8e8169 100644
--- a/amd/amdgpu/amdgpu_sa.c
+++ b/amd/amdgpu/amdgpu_sa.c
@@ -388,13 +388,8 @@ void amdgpu_sa_bo_dump_debug_info(struct amdgpu_sa_manager *sa_manager,
 			   soffset, eoffset, eoffset - soffset);
 
 		if (i->fence)
-#if defined(BUILD_AS_DKMS)
-			seq_printf(m, " protected by 0x%08x on context %d",
-					i->fence->seqno, i->fence->context);
-#else
 			seq_printf(m, " protected by 0x%08x on context %llu",
 				   i->fence->seqno, i->fence->context);
-#endif
 
 		seq_printf(m, "\n");
 	}
